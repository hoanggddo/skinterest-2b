ady computed `test_acc` using test_loader\n","print(\"\\n=== Final Results Summary ===\")\n","print(f\"MaxViT Condition Accuracy: {test_acc:.3f}\")  # replace test_acc with actual variable\n","\n","#  Lighting Classifier Accuracy\n","lighting_correct, lighting_total = 0, 0\n","for img_path, label in zip(test_df['image_path'], test_df['lighting_label']):\n","    img = Image.open(img_path).convert(\"RGB\")\n","    img_t = light_transform(img).unsqueeze(0).to(device)\n","    pred = lighting_model(img_t).argmax(1).item()\n","    lighting_total += 1\n","    if pred == label:\n","        lighting_correct += 1\n","\n","lighting_acc = lighting_correct / lighting_total\n","print(f\"Lighting Classifier Accuracy: {lighting_acc:.3f}\")\n","\n","# Undertone Classifier Accuracy\n","undertone_correct, undertone_total = 0, 0\n","for img_path, label in zip(test_df['image_path'], test_df['undertone_label']):\n","    f = extract_color_features(img_path)\n","    pred = undertone_model.predict([f])[0]\n","    undertone_total += 1\n","    if pred == label:\n","        undertone_correct += 1\n","\n","undertone_acc = undertone_correct / undertone_total\n","print(f\"Undertone Classifier Accuracy: {undertone_acc:.3f}\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"z9W0PhLJ8Udv","executionInfo":{"status":"ok","timestamp":1761426427155,"user_tz":240,"elapsed":7576,"user":{"displayName":"Hoang Do","userId":"17128267338028437900"}},"outputId":"3fb832dc-eb44-4a52-9582-4b9b933902da"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== Final Results Summary ===\n","MaxViT Condition Accuracy: 1.000\n","Lighting Classifier Accuracy: 0.888\n","Undertone Classifier Accuracy: 1.000\n"]}]}],"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyOVPW1C3D9QrVpINH2hj2tl"},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}