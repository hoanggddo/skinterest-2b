e(figsize=(10,10))\n","for i, idx in enumerate(samples):\n","    img, label = test_dataset[idx]\n","    with torch.no_grad():\n","        output = model(img.unsqueeze(0).to(device))\n","        pred = torch.argmax(output, 1).item()\n","\n","    plt.subplot(3, 3, i+1)\n","    plt.imshow(img.permute(1, 2, 0).cpu())\n","    plt.title(f\"True: {label}, Pred: {pred}\")\n","    plt.axis(\"off\")\n","\n","plt.tight_layout()\n","plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"fVf7B4zu9nmV","executionInfo":{"status":"ok","timestamp":1761420895061,"user_tz":240,"elapsed":11599,"user":{"displayName":"Hoang Do","userId":"17128267338028437900"}},"outputId":"e4e97804-cac7-499c-814f-ab02053c48bd"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x1000 with 9 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["from torchvision import transforms\n","\n","# Slightly augmented test transform\n","robust_transform = transforms.Compose([\n","    transforms.Resize((IMG_SIZE, IMG_SIZE)),\n","    transforms.ColorJitter(brightness=0.3, contrast=0.3),\n","    transforms.RandomRotation(10),\n","    transforms.ToTensor(),\n","])\n","\n","# Copy test_df, but apply this transform\n","robust_test_dataset = SkinDataset(test_df, transform=robust_transform)\n","robust_test_loader = DataLoader(robust_test_dataset, batch_size=BATCH_SIZE, shuffle=False)\n","\n","# Evaluate\n","model.eval()\n","correct, total = 0, 0\n","with torch.no_grad():\n","    for images, labels in robust_test_loader:\n","        images, labels = images.to(device), labels.to(device)\n","        outputs = model(images)\n","        _, preds = torch.max(outputs, 1)\n","        correct += (preds == labels).sum().item()\n","        total += labels.size(0)\n","\n","print(f\"Robustness Test Accuracy: {correct / total:.4f}\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"jZqgWMvg9qha","executionInfo":{"status":"ok","timestamp":1761420971395,"user_tz":240,"elapsed":68200,"user":{"displayName":"Hoang Do","userId":"17128267338028437900"}},"outputId":"295ae9ef-e799-4b5c-c177-3e7e9352e5a0"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Robustness Test Accuracy: 1.0000\n"]}]},{"cell_type":"code","source":["import torch.nn as nn\n","import torch.optim as optim\n","from torch.utils.data import DataLoader, Dataset\n","from torchvision import transforms\n","from PIL import Image\n","import numpy as np\n","import cv2\n","\n","# ====================================================\n","# Step 9: Lighting Classifier\n","# ====================================================\n","\n","# Simple transform (define this first)\n","light_transform = transforms.Compose([\n","    transforms.Resize((128, 128)),\n","    transforms.ToTensor(),\n","])\n","\n","# Lighting dataset\n","class LightingDataset(Dataset):\n","    def __init__(self, df, transform=None):\n","        self.df = df\n","        self.transform = transform\n","\n","    def __getitem__(self, idx):\n","        img = Image.open(self.df.iloc[idx]['image_path']).convert(\"RGB\")\n","        label = self.df.iloc[idx]['lighting_label']  # 0=soft, 1=harsh\n","        if self.transform:\n","            img = self.transform(img)\n","        return img, label\n","\n","    def __len__(self):\n","        return len(self.df)\n","\n","# Estimate lighting condition automatically\n","def estimate_lighting(image_path):\n","    img = cv2.imread(image_path)\n","    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)\n","    brightness = np.mean(gray)\n","    return 1 if brightness > 150 else 0  # 1=harsh, 0=soft\n","\n","# Add lighting labels to the DataFrame\n","train_df['lighting_label'] = train_df['image_path'].apply(estimate_lighting)\n","\n","#  Create dataset and dataloader\n","lighting_train = LightingDataset(train_df, light_transform)\n","lighting_loader = DataLoader(lighting_train, batch_size=8, shuffle=True)\n","\n","# Define simple CNN model\n","class LightingCNN(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.net = nn.Sequential(\n","            nn.Conv2d(3, 16, 3, 2, 1),\n","            nn.ReLU(),\n","            nn.Conv2d(16, 32, 3, 2, 1),\n","            nn.ReLU(),\n","            nn.AdaptiveAvgPool2d(1),\n","            nn.Flatten(),\n","            nn.Linear(32, 2)\n","        )\n","\n","    def forward(self, x):\n","        return self.net(x)\n","\n","# Train the model\n","lighting_model = LightingCNN().to(device)\n","criterion = nn.CrossEntropyLoss()\n","optimizer = optim.Adam(lighting_model.parameters(), lr=1e-3)\n","\n","for epoch in range(3):\n","    total, correct = 0, 0\n","    for imgs, labels in lighting_loader:\n","        imgs, labels = imgs.to(device), labels.to(device)\n","        preds = lighting_model(imgs)\n","        loss = criterion(preds, labels)\n","        optimizer.zero_grad()\n","        loss.backward()\n","        optimizer.step()\n","        total += labels.size(0)\n","        correct += (preds.argmax(1) == labels).sum().item()\n","    print(f\"Epoch {epoch+1}: Accuracy = {correct/total:.3f}\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"bDs9Wamwkv-f","executionInfo":{"status":"ok","timestamp":1761421409710,"user_tz":240,"elapsed":28051,"user":{"displayName":"Hoang Do","userId":"17128267338028437900"}},"outputId":"d02240bf-bb6a-4287-c405-d8ae7784ba9c"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Epoch 1: Accuracy = 0.831\n","Epoch 2: Accuracy = 0.831\n","Epoch 3: Accuracy = 0.831\n"]}]},{"cell_type":"code","source":["# ====================================================\n","# Step 10: Skin Undertone Classifier\n","# ====================================================\n","def extract_color_features(image_path):\n","    img = cv2.imread(image_path)\n","    img = cv2.cvtColor(img, cv2.COLOR_BGR2LAB)\n","    avg_color = np.mean(img.reshape(-1, 3), axis=0)\n","    return avg_color  # L, A, B channels\n","\n","# Create dataset of mean color values\n","features, labels = [], []\n","def estimate_undertone(image_path):\n","    img = cv2.imread(image_path)\n","    img_lab = cv2.cvtColor(img, cv2.COLOR_BGR2LAB)\n","    avg_a = np.mean(img_lab[:, :, 1])  # A channel (green–red)\n","    avg_b = np.mean(img_lab[:, :, 2])  # B channel (blue–yellow)\n","\n","    # Simple heuristic based on color channels\n","    if avg_a > 140 and avg_b > 140:\n","        return 2  # warm\n","    elif avg_a < 128 and avg_b < 128:\n","        return 0  # cool\n","    else:\n","        return 1  # neutral\n","\n","train_df['undertone_label'] = train_df['image_path'].apply(estimate_undertone)\n","for i in range(len(train_df)):\n","    f = extract_color_features(train_df.iloc[i]['image_path'])\n","    features.append(f)\n","    labels.append(train_df.iloc[i]['undertone_label'])  # 0=cool, 1=neutral, 2=warm\n","\n","features = np.array(features)\n","labels = np.array(labels)\n","\n","from sklearn.ensemble import RandomForestClassifier\n","from sklearn.metrics import accuracy_score\n","\n","undertone_model = RandomForestClassifier(n_estimators=100, random_state=42)\n","undertone_model.fit(features, labels)\n","\n","preds = undertone_model.predict(features)\n","print(\"Training Accuracy:\", accuracy_score(labels, preds))\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"gfdLV4n9k0j0","executionInfo":{"status":"ok","timestamp":1761421502118,"user_tz":240,"elapsed":16793,"user":{"displayName":"Hoang Do","userId":"17128267338028437900"}},"outputId":"63270784-c742-4adf-d633-d1c9914053d8"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Training Accuracy: 1.0\n"]}]},{"cell_type":"code","source":["val_df['lighting_label'] = val_df['image_path'].apply(estimate_lighting)\n","test_df['lighting_label'] = test_df['image_path'].apply(estimate_lighting)\n","\n","# Undertone label estimation (temporary for evaluation)\n","def estimate_undertone(image_path):\n","    f = extract_color_features(image_path)\n","    # predict using your trained undertone model\n","    return undertone_model.predict([f])[0]\n","\n","# Apply undertone labels to test set\n","test_df['undertone_label'] = test_df['image_path'].apply(estimate_undertone)\n","val_df['undertone_label'] = val_df['image_path'].apply(estimate_undertone)"],"metadata":{"id":"VEk6oX626r7D"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ====================================================\n","# Step 11: Validate Combined Classifiers\n","# ====================================================\n","def evaluate_combined(test_df):\n","    lighting_acc, undertone_acc = 0, 0\n","    for i in range(len(test_df)):\n","        img_path = test_df.iloc[i]['image_path']\n","\n","        # Lighting test\n","        img = Image.open(img_path).convert(\"RGB\")\n","        img_t = light_transform(img).unsqueeze(0).to(device)\n","        pred_light = lighting_model(img_t).argmax(1).item()\n","        if pred_light == test_df.iloc[i]['lighting_label']:\n","            lighting_acc += 1\n","\n","        # Undertone test\n","        f = extract_color_features(img_path)\n","        pred_under = undertone_model.predict([f])[0]\n","        if pred_under == test_df.iloc[i]['undertone_label']:\n","            undertone_acc += 1\n","\n","    print(f\"Lighting Classifier Accuracy: {lighting_acc/len(test_df):.3f}\")\n","    print(f\"Undertone Classifier Accuracy: {undertone_acc/len(test_df):.3f}\")\n","\n","evaluate_combined(test_df)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"7k5yLpsKk3AE","executionInfo":{"status":"ok","timestamp":1761421768759,"user_tz":240,"elapsed":4518,"user":{"displayName":"Hoang Do","userId":"17128267338028437900"}},"outputId":"b549b40e-0f98-48e9-df6c-015777ae7f0d"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Lighting Classifier Accuracy: 0.888\n","Undertone Classifier Accuracy: 1.000\n"]}]},{"cell_type":"code","source":["# ====================================================\n","# Step 12: Save Trained Models\n","# ====================================================\n","torch.save(lighting_model.state_dict(), \"/content/drive/MyDrive/SCIN/lighting_model.pth\")\n","torch.save(model.state_dict(), \"/content/drive/MyDrive//SCIN/maxvit_skin_model.pth\")  # main MaxViT model\n","import joblib\n","joblib.dump(undertone_model, \"/content/drive/MyDrive/SCIN/undertone_model.pkl\")\n","\n","print(\"All models saved successfully!\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"MJ8Q1YMi7lvh","executionInfo":{"status":"ok","timestamp":1761422239406,"user_tz":240,"elapsed":1184,"user":{"displayName":"Hoang Do","userId":"17128267338028437900"}},"outputId":"732cf840-54de-4e2a-b015-4e37060210f3"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["All models saved successfully!\n"]}]},{"cell_type":"code","source":["def full_prediction(image_path):\n","    # Lighting\n","    img = Image.open(image_path).convert(\"RGB\")\n","    img_t = light_transform(img).unsqueeze(0).to(device)\n","    light_pred = lighting_model(img_t).argmax(1).item()\n","    lighting = \"Harsh\" if light_pred == 1 else \"Soft\"\n","\n","    # Undertone\n","    color_feat = extract_color_features(image_path)\n","    undertone_pred = undertone_model.predict([color_feat])[0]\n","    undertone_map = {0: \"Cool\", 1: \"Neutral\", 2: \"Warm\"}\n","    undertone = undertone_map.get(undertone_pred, \"Unknown\")\n","\n","    print(f\"Lighting: {lighting}\")\n","    print(f\"Undertone: {undertone}\")\n","\n"],"metadata":{"id":"g1o7802y7tP5"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","\n","def visualize_predictions(df, n=5):\n","    for i in range(n):\n","        img_path = df.iloc[i]['image_path']\n","        img = 